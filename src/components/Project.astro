---
const { title, description, role, tech, link, slug } = Astro.props;
---

<div class={`project ${slug}`}>
    <div class="text_container">
        <h3>{title}</h3>

        <p>{description}</p>

        <p>
            <strong>Role:</strong>
            {role.join(", ")}
        </p>

        <p>
            <strong>Tech:</strong>
            {tech.join(", ")}
        </p>

    </div>
        {link && (
            <a href={link} target="_blank" class="link_btn">
            View Project
            </a>
        )}
    <div class="img_container">
        <img src=`/imgs/projects/${slug}.png` alt="">
    </div>
</div>

<style>
    .project {
        display: flex;
        flex-direction: column;
        height: max-content;
        gap: 0.5rem;
        /* background-color: rgb(241, 241, 243); */
        box-shadow: 0 10px 30px rgba(0, 30, 255, 0.15);
        border-radius: 1rem;
        /* margin-bottom: 5rem;  */
        padding: 1.5rem;  
        
        .text_container {
            
        }
        .link_btn {
            border-radius: 5rem;
            /* box-shadow: 0 7px 20px rgba(81,0,255,0.15); */
            background-color: rgba(0, 0, 255, 0.708);
            color: white;
            width: fit-content;
            padding: 0.25rem 0.75rem;
            margin: 0.25rem 0;

            &:hover {
                background-color: rgb(0, 0, 255);
                text-decoration: none;
            }
        }
        
        .img_container {

            img {
                width: 100%;
            }
        }
        
    }
</style>