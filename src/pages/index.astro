---
import Layout from "../layouts/Layout.astro";
import Gradient from "../components/Gradient.astro";
import Project from "../components/Project.astro";
import projects from "../projects.json";

const orderedProjects = [...projects].sort((a, b) => a.order - b.order);

---

<Layout>
  <div class="page">
    <section class="hero">
      <p>Hi, my name is</p>
      <p class="name_span">RONJA</p><p>and I am a multimediadesigner currently studying Web Development</p>
      <img class="star star1 hidden" src="../../public/imgs/star.png" alt="Star 1">
      <img class="star star2 hidden" src="../../public/imgs/star.png" alt="Star 2">
      <img class="star star3 hidden" src="../../public/imgs/star.png" alt="Star 3">
      <img class="star star4 hidden" src="../../public/imgs/star.png" alt="Star 4">
    </section>
    <section id="about">
      <div class="about_info_wrapper">
        <h1>About</h1>
        <div class="about_info_txt">
          <div class="who">
            <h3>Who am I?</h3>
            <p>
              My name is Ronja Baldursdóttir, an AP graduate in Multimediadesign, and a current
              student of Webdevelopment at the Copenhagen School of Design and Technology.
            </p>
          </div>
          <div class="what">
            <h3>What do I offer?</h3>
            <p>
              With a background in front-end development and design, I bring both creativity and
              technical expertise to the table. I enjoy collaborative environments, getting
              inspiration from teammates while continuously refining my work through feedback.
            </p>
          </div>
          <div class="goals">
            <h3>What are my goals?</h3>
            <p>
              I’m eager to join a team where I can continue growing my skills and developing
              as a webdeveloper. My goal is to further evolve both individually and in a group
              setting, while gaining real-world experience within the industry.
            </p>
          </div>
        </div>
      </div>
      <!-- <img class="hatGuy" src="/public/imgs/guy.png" alt="Guy" /> -->
      <img class="hatGuy" src="/public/imgs/hatGuy.png" alt="Guy" />
      <img class="nakedGuy" class="hidden" src="/public/imgs/nakedGuy.png" alt="Guy" />
    </section>

    <section id="experience">
      <h1>Experience</h1>
      <div class="experience_info_wrapper">
        <div class="education_info_wrapper">
          <h3>Education</h3>
          <div class="education_info_txt">
            <p>
              AP Degree in <span class="bold_span color">Multimedia Design</span> at Copenhagen School
              of Design and Technology (2023 - 2025)
            </p>
            <p>
              BA Degree in <span class="bold_span color">Web Development</span> at Copenhagen School of
              Design and Technology (2025 - 2027)
            </p>
          </div>
        </div>
        <div class="skills_info_wrapper">
          <h3>Skills</h3>
          <div class="skills_info_txt">
            <p>
              <span class="bold_span">Design: </span>
              UI design, Design Systems, Prototyping, User & Design Research
            </p>
            <p>
              <span class="bold_span">Languages & Technologies: </span>
              HTML, CSS, JavaScript, PHP, Python, Astro, Next.js, Tailwind CSS, WordPress 
            <p>
              <span class="bold_span">Tools & Software: </span>
              Git, Figma, Illustrator, Photoshop, Premiere Pro, After Effects, Elementor
            </p>
            <p>
              <span class="bold_span">Databases & APIs: </span>
              MariaDB, SQL, Supabase, REST API
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
  <section id="projects">
    <h1>Projects</h1>
    <div class="project_container">
    {orderedProjects.map((project) => (
      <Project {...project} />
    ))}
    </div>
  </section>
</Layout>

<script>
  const name = document.querySelector(".name_span");
  name.addEventListener("mouseenter", () => {
    document.querySelectorAll(".star").forEach(star => {
      star.classList.remove("hidden");
    });
  });
  name.addEventListener("mouseleave", () => {
    document.querySelectorAll(".star").forEach(star => {
      star.classList.add("hidden");
    });
  });
  const hatGuy = document.querySelector(".hatGuy");
  const nakedGuy = document.querySelector(".nakedGuy");
    hatGuy.addEventListener("click", ()=>{
      hatGuy.classList.add("hidden");
      nakedGuy.classList.remove("hidden");
    });
    nakedGuy.addEventListener("click", ()=>{
      hatGuy.classList.remove("hidden");
      nakedGuy.classList.add("hidden");
    });
</script>

<style>
  .page, #projects {
      margin: 7rem 4rem;
      
    }

    .page {
      scroll-snap-type: y mandatory;
    }

  .hero {
    
    .star {
      position: absolute;
    }
    .star1 {
      top: 2.5rem;
      left: 10rem;
      width: 15rem;
    }
    .star2 {
      bottom: 5rem;
      right: 10px;
      width: 10rem;
    }
    .star3 {
      right: 10rem;
      bottom: 100px;
      width: 25rem;
    }
    .star4 {
      right: 10rem;
      top: 100px;
      width: 7.5rem;
    }
  }
  section {
    height: 100vh;
    /* width: 60%; */
  }

  .name_span {
    color: var(--accent);
    font-weight: bold;
    font-size: 200px;
    width: 100%;
    height: auto;
  }

  .bold_span {
    font-weight: 700;
  }

  #about {
    width: 80%;
    display: flex;
    gap: 6rem;
    img {
      height: 50%;
    }

    .about_info_wrapper {
      gap: 1.5rem;
    }
    .about_info_txt {
      gap: 2.5rem;
      > * {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
    }

    .about_info_txt,
    .about_info_wrapper {
      display: flex;
      flex-direction: column;
    }
  }
  #experience {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;

    .experience_info_wrapper {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;

      > * {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
    }
  }

  #projects {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    height: fit-content;
    .project_container {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      
      gap: 3rem;
    }
  }
  .project_wrapper {
    display: flex;
    height: 90vh;
  }
  .project_text_wrapper {
    position: absolute;
    width: 60%;
    height: fit-content;
  }

 
  
  .flex {
    display: flex;
    gap: 2.5rem;
  }

 

  .color {
    color: var(--accent);
  }
</style>
